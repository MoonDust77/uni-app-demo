<view bind:__l="__l"><view class="author-info-box flex"><avatar-img headPicUrl="{{author.authorPic}}" avatarHeight="{{140}}"></avatar-img><view class="author-info"><view class="author-name"><text>{{author.authorName}}</text></view><view class="author-authentication"><text>{{author.authenticationInfo}}</text></view></view></view><view class="title"><text>文章</text></view><block wx:if="{{articles.length>0}}"><view class="list-box"><block wx:for="{{articles}}" wx:for-item="article" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['goDetailPage',[article.articleID]]]]]}}" class="list-item" bindtap="__e"><article-abstract headerPicUrls="{{article.headerPicUrls}}" content="{{article.content}}"></article-abstract><article-footer browseCount="{{article.browseCount}}"></article-footer></view></block></view></block></view>