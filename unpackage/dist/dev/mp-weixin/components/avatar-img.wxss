
.avatar-box {
	position: relative;
}
.avatar {
	height: 52rpx;
	width: 52rpx;
	border-radius: 100%;
}
.icon-v {
	position: absolute;
	bottom: 0;
	right: 0;
}
.icon-v.small {
	height: 20rpx;
	width: 20rpx;
	background-image: url(data:image/png;base64,);
	background-size: contain;
}
.icon-v.big {
	height: 32rpx;
	width: 32rpx;
	background-image: url(data:image/png;base64,);
	background-size: contain;
}

