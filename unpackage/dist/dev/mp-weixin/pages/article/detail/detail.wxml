<view bind:__l="__l"><swiper class="swiper" indicator-dots="{{true}}" autoplay="{{true}}"><block wx:for="{{article.headerPicUrls}}" wx:for-item="headerPicUrl" wx:for-index="index" wx:key="index"><swiper-item><image class="ad-image" mode="widthFix" src="{{host.imgHost+headerPicUrl}}"></image></swiper-item></block></swiper><view class="main-section"><view class="article-title-box"><text>{{article.articleTitle}}</text></view><block wx:if="{{author.authorPic}}"><avatar author="{{author}}"></avatar></block><view class="content-box"></view><article-footer browseCount="{{article.browseCount}}" showLike="{{false}}"></article-footer></view><view class="main-section pb-16"><view class="main-section-title"><text>更多内容</text></view><block wx:if="{{moreArticleList.length>0}}"><view class="list-col-2 flex"><block wx:for="{{moreArticleList}}" wx:for-item="article" wx:key="article.article.articleID"><view data-event-opts="{{[['tap',[['goDetailPage',[article.article.articleID]]]]]}}" class="list-item" bindtap="__e"><article-abstract headerPicUrls="{{article.article.headerPicUrls}}" content="{{article.article.content}}" imageHeight="{{164}}"></article-abstract><view class="footer-wrapper"><block wx:if="{{article.author.authorPic}}"><avatar author="{{article.author}}" height="{{74}}" avatarHeight="{{34}}"></avatar></block></view></view></block></view></block></view></view>