<view class="content" bind:__l="__l"><block wx:if="{{headerPicUrls.length>1}}"><swiper style="{{'height:'+(imageHeight+'upx')+';'}}"><block wx:for="{{headerPicUrls}}" wx:for-item="picUrl" wx:for-index="picIndex" wx:key="picIndex"><swiper-item><image class="content-img" style="{{'height:'+(imageHeight+'upx')+';'}}" src="{{host.imgHost+picUrl}}" mode="widthFix"></image></swiper-item></block></swiper></block><block wx:else><image class="content-img" src="{{host.imgHost+headerPicUrls[0]}}" mode="widthFix"></image></block><view class="content-text"><text>{{content}}</text></view></view>