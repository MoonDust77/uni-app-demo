<view class="page" bind:__l="__l"><scroll-view class="scroll-view_H" scroll-x="true" data-event-opts="{{[['scroll',[['scroll',['$event']]]]]}}" bindscroll="__e"><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="item.categoryID"><view class="{{['scroll-view-item_H',(index===currentIndex)?'active':'']}}" id="{{item.categoryID}}" data-event-opts="{{[['tap',[['clickCategory',[index]]]]]}}" bindtap="__e">{{item.categoryName}}</view></block></scroll-view><swiper class="swiper" current="{{currentIndex}}" data-event-opts="{{[['change',[['handleChangeSwiper',['$event']]]]]}}" bindchange="__e"><block wx:for="{{list}}" wx:for-item="item" wx:key="item.categoryID"><swiper-item><view class="swiper-item"><block wx:if="{{item.articleList&&item.articleList.banners&&item.articleList.banners.length>0}}"><view class="ad-box"><swiper indicator-dots="{{true}}" autoplay="{{true}}"><block wx:for="{{item.articleList.banners}}" wx:for-item="banner" wx:for-index="index" wx:key="index"><swiper-item><view class="ad-image-wrapper"><image class="ad-image" mode="scaleToFill" src="{{host.imgHost+banner.picUrl}}"></image></view></swiper-item></block></swiper></view></block><block wx:if="{{item.articleList&&item.articleList.articles&&item.articleList.articles.length>0}}"><view class="list-box"><block wx:for="{{item.articleList.articles}}" wx:for-item="article" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['goDetailPage',[article.article.articleID]]]]]}}" class="list-item" bindtap="__e"><avatar author="{{article.author}}"></avatar><article-abstract headerPicUrls="{{article.article.headerPicUrls}}" content="{{article.article.content}}"></article-abstract><article-footer browseCount="{{article.article.browseCount}}"></article-footer></view></block></view></block></view></swiper-item></block></swiper></view>